{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "preserve",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "paths": {
      "@components/*": ["./components/*"],
      "@modules/*": ["./modules/*"],
      "@sections/*": ["./components/Main/*"],
      "@perks/*": ["./components/Main/Perks Section/*"],
      "@logs/*": ["./components/Main/Logs Section/*"],
      "@projects/*": ["./components/Main/Projects Section/*"],
      "@styleVariables": ["./style/variables.scss"]
    },
    "types": ["vite/client"]
  },
  "include": ["**/*.ts", "**/*.d.ts", "**/*.vue"]
}